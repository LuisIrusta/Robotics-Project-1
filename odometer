  void runge_kutta_2 ( //Approximate the odometry calculation using RK2 method - DONE
    double &x, double &y, double &theta, 
    const double &v, const double &omega, const double &dt)
  {
    double theta_mid = theta_ + omega * dt / 2.0;
    x     += v * std::cos(theta_mid) * dt;
    y     += v * std::sin(theta_mid) * dt;
    theta += omega * dt;

    // theta should be in the [-pi, pi] interval
    theta = std::atan2(std::sin(theta), std::cos(theta));
  }

  void reset_handle( //DONE
    const std::shared_ptr<reset::srv::Empty::Request> request,
    std::shared_ptr<reset::srv::Empty::Response> response)
    {
        _x = 0.0;
        _y = 0.0;
        _theta = 0.0;
        RCLCPP_INFO(this->get_logger(), "Odometry parameters have been reset to default values.")
  }
};

